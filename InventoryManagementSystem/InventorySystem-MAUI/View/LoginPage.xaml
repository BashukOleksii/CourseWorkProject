<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.LoginPage"
             xmlns:vm="clr-namespace:InventorySystem_MAUI.ViewModel"
             x:DataType="vm:LoginViewModel"
             Shell.NavBarIsVisible="False"
             xmlns:components="clr-namespace:InventorySystem_MAUI.View.Components"
             Shell.PresentationMode="Modal">

    <Grid>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#4F46E5" Offset="0.0"/>
                <GradientStop Color="#9333EA" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="25" Spacing="0" VerticalOptions="Center">


                <Label Text="Ласкаво просимо"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"/>

                <Label Text="Увійдіть, щоб керувати інвентарем"
                       FontSize="14"
                       TextColor="#E0E0E0"
                       HorizontalOptions="Center"
                       Margin="0,5,0,30"/>

                <Border StrokeShape="RoundRectangle 25"
                        BackgroundColor="White"
                        Padding="25"
                        Margin="0,0,0,20">

                    <Border.Shadow>
                        <Shadow Brush="#000000"
                                Opacity="0.2"
                                Offset="0,5"
                                Radius="15"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="18">

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Email"
                                   FontAttributes="Bold"
                                   TextColor="#333"/>

                            <Border Stroke="#E5E7EB"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="10">
                                <Entry Text="{Binding Email}"
                                       Placeholder="your@email.com"
                                       Keyboard="Email"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Пароль"
                                   FontAttributes="Bold"
                                   TextColor="#333"/>

                            <Border Stroke="#E5E7EB"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="10">
                                <Entry Text="{Binding Password}"
                                       Placeholder="*********"
                                       IsPassword="True"/>
                            </Border>
                        </VerticalStackLayout>

                        <Label Text="Забули пароль?"
                               TextColor="#6366F1"
                               FontSize="13"
                               HorizontalOptions="End">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ForgotPasswordCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>

                        <Button Text="Увійти"
                                Command="{Binding LoginCommand}"
                                HeightRequest="55"
                                CornerRadius="18"
                                FontAttributes="Bold"
                                TextColor="White"
                                BackgroundColor="#6366F1"
                                Margin="0,10,0,5"
                                IsEnabled="{Binding IsNotBusy}"/>

                    </VerticalStackLayout>
                </Border>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                    <Label Text="Немає облікового запису?"
                           TextColor="White"
                           FontSize="14"/>

                    <Label Text="Створити акаунт"
                           TextColor="#C7D2FE"
                           FontAttributes="Bold"
                           FontSize="14">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToRegisterCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <components:LoadingOverlay/>

    </Grid>
</ContentPage>