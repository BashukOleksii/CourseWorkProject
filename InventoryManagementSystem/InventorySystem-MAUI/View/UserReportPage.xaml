<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.UserReportPage"
             xmlns:vm="clr-namespace:InventorySystem_MAUI.ViewModel"
             xmlns:u="clr-namespace:InventorySystem_Shared.User;assembly=InventorySystem-Shared"
             xmlns:components="clr-namespace:InventorySystem_MAUI.View.Components"
             x:DataType="vm:UserReportViewModel"
             BackgroundColor="#F8F9FA"
             Shell.PresentationMode="Modal">

    <Grid RowDefinitions="Auto, *">
        <BoxView Grid.Row="0" HeightRequest="40" BackgroundColor="#4F46E5" VerticalOptions="Start"/>

        <Grid Grid.Row="0" Grid.RowSpan="2" RowDefinitions="Auto, *">

            <VerticalStackLayout Grid.Row="0" Margin="15,5,15,10" Spacing="10">
                <Border StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="15">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.15" Offset="0,4" Radius="10"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*, Auto, Auto">
                            <Label Text="Аналітика персоналу" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" TextColor="#111827"/>
                            <ImageButton Grid.Column="1" Source="filter.png" Command="{Binding ToggleFiltersCommand}" HeightRequest="30" Margin="0,0,10,0"/>
                            <Button Grid.Column="2" Text="ЗВІТ" Command="{Binding GeneratePdfReportCommand}" BackgroundColor="#EF4444" HeightRequest="35" FontSize="12" FontAttributes="Bold"/>
                        </Grid>

                        <VerticalStackLayout IsVisible="{Binding IsFilterVisible}" Spacing="12" Margin="0,10,0,0">

                            <Border Stroke="#E5E7EB" StrokeShape="RoundRectangle 8" Padding="10" BackgroundColor="#F9FAFB">
                                <Entry Placeholder="Пошук за ім'ям..." Text="{Binding Query.Name}" TextColor="#111827"/>
                            </Border>

                            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                                <Border Grid.Column="0" Stroke="#E5E7EB" StrokeShape="RoundRectangle 8" Padding="5" BackgroundColor="#F9FAFB">
                                    <Picker Title="Роль" ItemsSource="{Binding Roles}" SelectedItem="{Binding Query.UserRole}" HorizontalOptions="Fill"/>
                                </Border>
                                <Border Grid.Column="1" Stroke="#E5E7EB" StrokeShape="RoundRectangle 8" Padding="10" BackgroundColor="#F9FAFB">
                                    <Entry Placeholder="ID Складу" Text="{Binding Query.WarehouseId}" TextColor="#111827" FontSize="12"/>
                                </Border>
                            </Grid>

                            <Button Text="Застосувати" 
                                    Command="{Binding ApplyFiltersCommand}" 
                                    BackgroundColor="#4F46E5"
                                    FontAttributes="Bold"
                                    CornerRadius="8"
                                    HeightRequest="45"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <CollectionView Grid.Row="1" ItemsSource="{Binding Users}" Margin="15,0">
                <CollectionView.Header>
                    <Label Text="Знайдені співробітники" FontSize="14" FontAttributes="Bold" Margin="5,0,0,10" TextColor="#6B7280"/>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="u:UserResponse">
                        <components:UserCardView 
                            EditCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:UserReportViewModel}}, Path=EditUserCommand}"
                            DeleteCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:UserReportViewModel}}, Path=DeleteUserCommand}"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.Footer>
                    <BoxView HeightRequest="80" Color="Transparent"/>
                </CollectionView.Footer>
            </CollectionView>
        </Grid>

        <components:PaginationControl Grid.Row="1" 
                                      VerticalOptions="End"
                                      PageNumber="{Binding CurrentPage}"
                                      CanNext="{Binding CanGoNext}"
                                      NextCommand="{Binding NextPageCommand}"
                                      PrevCommand="{Binding PreviousPageCommand}"/>

        <components:LoadingOverlay Grid.RowSpan="2" />
    </Grid>
</ContentPage>