<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.AddressCreatePage"
             xmlns:vm="clr-namespace:InventorySystem_MAUI.ViewModel"
             x:DataType="vm:AddressCreateViewModel"
             Title="AddressCreatePage"
             Shell.PresentationMode="Modal">
    
    
    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15">
            <Label Text="Пошук за координатами" Style="{StaticResource SubHeadline}"/>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Entry Placeholder="Широта (Lat)" Text="{Binding Latitude}" Keyboard="Numeric"/>
                <Entry Grid.Column="1" Placeholder="Довгота (Lon)" Text="{Binding Longitude}" Keyboard="Numeric"/>
            </Grid>
            <Button Text="Знайти за координатами" Command="{Binding GetByCoordsCommand}" BackgroundColor="{StaticResource Secondary}"/>

            <BoxView HeightRequest="1" Margin="0,10"/>

            <Label Text="Пошук за адресою" Style="{StaticResource SubHeadline}"/>
            <Entry Placeholder="Країна" Text="{Binding Country}"/>
            <Entry Placeholder="Область" Text="{Binding State}"/>
            <Entry Placeholder="Місто" Text="{Binding City}"/>
            <Entry Placeholder="Вулиця" Text="{Binding Street}"/>
            <Entry Placeholder="Номер будинку" Text="{Binding HouseNumber}"/>

            <Button Text="Перевірити адресу" Command="{Binding GetByTextCommand}" IsEnabled="{Binding IsNotBusy}"/>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"/>

            <Button Text="Підтвердити" 
                    Command="{Binding SaveAndCloseCommand}"
                    Margin="0,20,0,0"
                    HeightRequest="50"
                    FontAttributes="Bold"
                    IsEnabled="{Binding IsNotBusy}"/>
        </VerticalStackLayout>
    </ScrollView>
    
</ContentPage>