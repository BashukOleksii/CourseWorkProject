<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.LogPage"
             xmlns:vm="clr-namespace:InventorySystem_MAUI.ViewModel"
             xmlns:log="clr-namespace:InventorySystem_Shared.Loging;assembly=InventorySystem-Shared"
             xmlns:components="clr-namespace:InventorySystem_MAUI.View.Components"
             x:DataType="vm:LogViewModel"
             BackgroundColor="#F8F9FA">

    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" Grid.RowSpan="2" RowDefinitions="Auto, *">

            <VerticalStackLayout Grid.Row="0" Margin="15,10" Spacing="10">
                <Border StrokeShape="RoundRectangle 16" BackgroundColor="White" Padding="15">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.1" Offset="0,4" Radius="10"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*, Auto, Auto">
                            <Label Text="Логи аудиту" FontSize="22" FontAttributes="Bold" VerticalOptions="Center"/>
                            <Button Grid.Column="1" Text="Очистити" Command="{Binding ResetFiltersCommand}" 
                                    BackgroundColor="Transparent" TextColor="Gray" FontSize="12"/>
                            <ImageButton Grid.Column="2" Source="filter.png" Command="{Binding ToggleFiltersCommand}" HeightRequest="30"/>
                        </Grid>

                        <VerticalStackLayout IsVisible="{Binding IsFilterVisible}" Spacing="12" Margin="0,10,0,0">
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Border Style="{StaticResource InputWrapperStyle}" Grid.Column="0">
                                    <Entry Placeholder="User ID" Text="{Binding Query.UserId}" FontSize="12"/>
                                </Border>
                                <Border Style="{StaticResource InputWrapperStyle}" Grid.Column="1">
                                    <Entry Placeholder="Ім'я" Text="{Binding Query.UserName}" FontSize="12"/>
                                </Border>
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Border Style="{StaticResource InputWrapperStyle}" Grid.Column="0">
                                    <Entry Placeholder="Entity ID" Text="{Binding Query.EntityId}" FontSize="12"/>
                                </Border>
                                <Border Style="{StaticResource InputWrapperStyle}" Grid.Column="1">
                                    <Picker Title="Тип об'єкта" ItemsSource="{Binding EntityOptions}" SelectedItem="{Binding Query.EntityType}" FontSize="12"/>
                                </Border>
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Picker Title="Роль" ItemsSource="{Binding RoleOptions}" SelectedItem="{Binding Query.Role}" Grid.Column="0"/>
                                <Picker Title="Дія" ItemsSource="{Binding ActionOptions}" SelectedItem="{Binding Query.Action}" Grid.Column="1"/>
                            </Grid>

                            <Label Text="Часовий проміжок:" FontSize="12" TextColor="Gray" Margin="5,0"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <DatePicker Date="{Binding Query.From}" Grid.Column="0"/>
                                <DatePicker Date="{Binding Query.To}" Grid.Column="1"/>
                            </Grid>

                            <Button Text="Застосувати пошук" Command="{Binding ApplyFiltersCommand}" 
                                    BackgroundColor="#4F46E5" FontAttributes="Bold" CornerRadius="12" HeightRequest="45"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <CollectionView Grid.Row="1" ItemsSource="{Binding Logs}" Margin="15,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="log:AuditLogResponse">
                        <Border StrokeShape="RoundRectangle 12" Margin="0,5" Padding="15" BackgroundColor="White">
                            <Grid ColumnDefinitions="4, *, Auto" ColumnSpacing="15">
                                <BoxView Color="{Binding Action, Converter={StaticResource ActionToColorConverter}}" VerticalOptions="Fill"/>

                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <VerticalStackLayout Spacing="0">
                                        <Label Text="{Binding UserName}" FontAttributes="Bold" FontSize="15" TextColor="#111827"/>
                                        <Label Text="{Binding UserId, StringFormat='User ID: {0}'}" FontSize="10" TextColor="#9CA3AF"/>
                                    </VerticalStackLayout>

                                    <Label FontSize="13" TextColor="#374151">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding Action}" FontAttributes="Bold" TextColor="#4F46E5"/>
                                                <Span Text=" → "/>
                                                <Span Text="{Binding EntityType}" FontAttributes="Bold"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>

                                    <Label Text="{Binding EntityId, StringFormat='Entity ID: {0}'}" FontSize="10" TextColor="#6B7280"/>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="2" HorizontalOptions="End" VerticalOptions="Center">
                                    <Label Text="{Binding TimeStamp, StringFormat='{0:dd.MM}'}" FontSize="11" TextColor="Gray" HorizontalOptions="End"/>
                                    <Label Text="{Binding TimeStamp, StringFormat='{0:HH:mm}'}" FontSize="13" FontAttributes="Bold" HorizontalOptions="End"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.Footer>
                    <BoxView HeightRequest="100" Color="Transparent"/>
                </CollectionView.Footer>
            </CollectionView>
        </Grid>

        <components:PaginationControl Grid.Row="1" VerticalOptions="End"
                                      PageNumber="{Binding CurrentPage}" CanNext="{Binding CanGoNext}"
                                      NextCommand="{Binding NextPageCommand}" PrevCommand="{Binding PreviousPageCommand}"/>

        <components:LoadingOverlay Grid.RowSpan="2"/>
    </Grid>
</ContentPage>