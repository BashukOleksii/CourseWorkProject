<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.Components.LoadingOverlay">

    <Grid BackgroundColor="#80000000" 
          IsVisible="{Binding IsBusy}" 
          InputTransparent="False">
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="15">
            <ActivityIndicator IsRunning="{Binding IsBusy}" Color="White" HeightRequest="60" WidthRequest="60"/>
            <Label Text="Завантаження..." TextColor="White" FontAttributes="Bold" HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </Grid>
</ContentView>