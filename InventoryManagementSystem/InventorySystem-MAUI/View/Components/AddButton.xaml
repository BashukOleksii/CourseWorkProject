
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.Components.AddButton">

    <Button Text="+"
        FontSize="30"
        TextColor="White"
        BackgroundColor="#6366F1"
        HeightRequest="60"
        WidthRequest="60"
        CornerRadius="30"
        HorizontalOptions="End"
        VerticalOptions="End"
        Margin="20"
        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=AddCommand}">
        <Button.Shadow>
            <Shadow Brush="Black" Opacity="0.3" Offset="0,5" Radius="10"/>
        </Button.Shadow>

    </Button>
</ContentView>