<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:InventorySystem_MAUI.ViewModel"
             x:Class="InventorySystem_MAUI.View.Components.UserCardView"
             x:Name="this">

    <Border StrokeShape="RoundRectangle 16" 
            BackgroundColor="White" 
            Padding="15" 
            Margin="0,5">

        <Border.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding Source={x:Reference this}, Path=EditCommand}" 
                                  CommandParameter="{Binding BindingContext, Source={x:Reference this}}"/>
        </Border.GestureRecognizers>

        <Border.Shadow>
            <Shadow Brush="Black" Opacity="0.05" Offset="0,2" Radius="5"/>
        </Border.Shadow>

        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">

            <Border Grid.Column="0" 
                    HeightRequest="55" 
                    WidthRequest="55" 
                    StrokeShape="RoundRectangle 27.5">
                <Image Source="{Binding PhotoURI, Converter={StaticResource UriConverter}}" 
                       Aspect="AspectFill"/>
            </Border>

            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                <Label Text="{Binding Name}" 
                       FontSize="17" 
                       FontAttributes="Bold" 
                       TextColor="#111827"/>

                <Label Text="{Binding UserRole}" 
                       FontSize="13" 
                       TextColor="#4F46E5" 
                       FontAttributes="Bold"/>

                <Label Text="{Binding Email}" 
                       FontSize="13" 
                       TextColor="#6B7280"/>
            </VerticalStackLayout>

            <ImageButton Grid.Column="2" 
                         Source="delete_icon.png" 
                         BackgroundColor="Transparent"
                         VerticalOptions="Center"
                         HeightRequest="35" 
                         WidthRequest="35"
                         Command="{Binding Source={x:Reference this}, Path=DeleteCommand}"
                         CommandParameter="{Binding BindingContext, Source={x:Reference this}}"/>
        </Grid>
    </Border>
</ContentView>