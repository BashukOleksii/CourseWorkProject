<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.Components.ManufacturerCard"
             x:Name="this">

    <Border StrokeShape="RoundRectangle 16" BackgroundColor="White" Padding="15" Margin="0,5">
        <Border.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding Source={x:Reference this}, Path=EditCommand}" 
                                  CommandParameter="{Binding BindingContext, Source={x:Reference this}}"/>
        </Border.GestureRecognizers>

        <Grid ColumnDefinitions="Auto, *, Auto">
            <Border Grid.Column="0" HeightRequest="50" WidthRequest="50" StrokeShape="RoundRectangle 25" BackgroundColor="#F3F4F6">
                <Label Text="🏭" HorizontalOptions="Center" VerticalOptions="Center" FontSize="20"/>
            </Border>

            <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="15,0" VerticalOptions="Center">
                <Label Text="{Binding Name}" FontSize="17" FontAttributes="Bold" TextColor="#111827"/>
                <Label Text="{Binding Country, StringFormat='Країна: {0}'}" FontSize="13" TextColor="#6B7280"/>
            </VerticalStackLayout>

            <ImageButton Grid.Column="2" 
                         Source="delete_icon.png" 
                         BackgroundColor="Transparent"
                         HeightRequest="35" WidthRequest="35"
                         Command="{Binding Source={x:Reference this}, Path=DeleteCommand}"
                         CommandParameter="{Binding BindingContext, Source={x:Reference this}}"/>
        </Grid>
    </Border>
</ContentView>