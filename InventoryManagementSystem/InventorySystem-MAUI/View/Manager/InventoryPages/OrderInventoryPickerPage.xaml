<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:InventorySystem_MAUI.ViewModel"
             xmlns:shared="clr-namespace:InventorySystem_Shared;assembly=InventorySystem-Shared"
             xmlns:components="clr-namespace:InventorySystem_MAUI.View.Components"
             x:Class="InventorySystem_MAUI.View.Manager.InventoryPages.OrderInventoryPickerPage"
             x:DataType="viewmodel:OrderInventoryPickerViewModel"
             Title="Вибір товарів">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Готово" Command="{Binding SaveAndCloseCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, *, Auto">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#4F46E5" Offset="0.0"/>
                <GradientStop Color="#9333EA" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Frame Grid.Row="0" 
               Margin="10" 
               Padding="12" 
               CornerRadius="15" 
               BackgroundColor="#CCFFFFFF" 
               HasShadow="False"
               BorderColor="Transparent">
            <VerticalStackLayout Spacing="8">

                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="5">
                    <SearchBar Placeholder="Швидкий пошук назви..." 
                               Text="{Binding Query.Name}" 
                               BackgroundColor="White"
                               SearchCommand="{Binding LoadDataCommand}"
                               HeightRequest="45"/>
                    <Button Grid.Column="1" 
                            Text="⚙️" 
                            ToolTipProperties.Text="Фільтри"
                            Command="{Binding ToggleFilterCommand}" 
                            Style="{StaticResource ButtonPrimary}"
                            WidthRequest="45"
                            HeightRequest="45" />
                </Grid>

                <VerticalStackLayout IsVisible="{Binding IsFilterVisible}" Spacing="10" Padding="0,10,0,5">
                    <BoxView HeightRequest="1" Color="#E5E7EB" Margin="0,5"/>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10" RowDefinitions="Auto, Auto, Auto">
                        <Picker Grid.Row="0" Grid.Column="0" Title="Тип товару" 
                                ItemsSource="{Binding InventoryTypes}" 
                                SelectedItem="{Binding Query.InventoryType}" 
                                BackgroundColor="White"/>

                        <Entry Grid.Row="0" Grid.Column="1" Placeholder="Виробник" 
                               Text="{Binding Query.Manufacturer.Name}" 
                               BackgroundColor="White"/>

                        <Entry Grid.Row="1" Grid.Column="0" Placeholder="Мін. ціна" 
                               Text="{Binding Query.MinPrice}" Keyboard="Numeric" 
                               BackgroundColor="White"/>

                        <Entry Grid.Row="1" Grid.Column="1" Placeholder="Макс. ціна" 
                               Text="{Binding Query.MaxPrice}" Keyboard="Numeric" 
                               BackgroundColor="White"/>

                        <Entry Grid.Row="2" Grid.Column="0" Placeholder="Мін. к-ть" 
                               Text="{Binding Query.MinQuantity}" Keyboard="Numeric" 
                               BackgroundColor="White"/>

                        <Entry Grid.Row="2" Grid.Column="1" Placeholder="Макс. к-ть" 
                               Text="{Binding Query.MaxQuantity}" Keyboard="Numeric" 
                               BackgroundColor="White"/>
                    </Grid>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,5">
                        <Button Text="Застосувати" 
                                Command="{Binding LoadDataCommand}" 
                                Style="{StaticResource ButtonPrimary}" />
                        <Button Text="Скинути" 
                                Command="{Binding ResetFiltersCommand}" 
                                Style="{StaticResource ButtonSecondary}" />
                    </Grid>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,5,0,0">
                    <Button Grid.Column="0" Text="Вибрати сторінку" 
                            Command="{Binding SelectAllOnPageCommand}" 
                            FontSize="11" HeightRequest="35" Style="{StaticResource ButtonSecondary}"/>
                    <Button Grid.Column="1" Text="Вибрати весь склад" 
                            Command="{Binding SelectAllInWarehouseCommand}" 
                            FontSize="11" HeightRequest="35" Style="{StaticResource ButtonSecondary}"/>
                </Grid>
            </VerticalStackLayout>
        </Frame>

        <RefreshView Grid.Row="1" Command="{Binding LoadDataCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Items}">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="30">
                        <Label Text="Товарів не знайдено 🔎" TextColor="White" FontSize="18" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodel:SelectableInventoryItem">
                        <Grid Padding="10,5">
                            <Border StrokeShape="RoundRectangle 15" StrokeThickness="0" Padding="12" BackgroundColor="#CCFFFFFF">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Stroke" Value="{StaticResource Primary}" />
                                        <Setter Property="StrokeThickness" Value="2" />
                                        <Setter Property="BackgroundColor" Value="White" />
                                    </DataTrigger>
                                </Border.Triggers>

                                <Grid ColumnDefinitions="70, *, Auto" ColumnSpacing="15">
                                    <Border StrokeShape="RoundRectangle 10"  HeightRequest="70" WidthRequest="70">
                                        <Image Source="{Binding Item.PhotoURI, Converter={StaticResource UriConverter}}" 
                                               Aspect="AspectFill" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                        <Label Text="{Binding Item.Name}" FontAttributes="Bold" FontSize="16" TextColor="#1F2937" LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding Item.Manufacturer.Name, StringFormat='Виробник: {0}'}" FontSize="12" TextColor="#6B7280" />
                                        <Label Text="{Binding Item.Price, StringFormat='{0:N2} грн'}" TextColor="#4F46E5" FontAttributes="Bold" FontSize="14" />
                                    </VerticalStackLayout>

                                    <CheckBox Grid.Column="2" IsChecked="{Binding IsSelected}" VerticalOptions="Center" Color="#4F46E5" InputTransparent="True" />
                                </Grid>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:OrderInventoryPickerViewModel}}, Path=ToggleSelectionCommand}" 
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <components:PaginationControl Grid.Row="2"
                                      VerticalOptions="End"
                                      PageNumber="{Binding CurrentPage}" 
                                      CanNext="{Binding CanGoNext}"
                                      NextCommand="{Binding NextPageCommand}" 
                                      PrevCommand="{Binding PreviousPageCommand}"/>

        <components:LoadingOverlay Grid.RowSpan="3" IsVisible="{Binding IsBusy}"/>
    </Grid>
</ContentPage>