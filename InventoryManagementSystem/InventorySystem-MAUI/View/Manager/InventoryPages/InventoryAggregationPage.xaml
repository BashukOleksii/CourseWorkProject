<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.InventoryAggregationPage"
             xmlns:vm="clr-namespace:InventorySystem_MAUI.ViewModel"
             xmlns:m="clr-namespace:InventorySystem_Shared.Inventory;assembly=InventorySystem-Shared"
             xmlns:components="clr-namespace:InventorySystem_MAUI.View.Components"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:DataType="vm:InventoryAggregationViewModel"
             Title="Агрегація даних"
             BackgroundColor="#F3F4F6">

    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" BackgroundColor="#4F46E5" StrokeThickness="0" Padding="15">
            <Grid ColumnDefinitions="*, Auto">
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <Button Text="JSON" Command="{Binding ExportDataCommand}" CommandParameter="json" HeightRequest="35" FontSize="12" BackgroundColor="#6366F1"/>
                    <Button Text="XML" Command="{Binding ExportDataCommand}" CommandParameter="xml" HeightRequest="35" FontSize="12" BackgroundColor="#6366F1"/>
                    <Button Text="Імпорт" Command="{Binding ImportDataCommand}" HeightRequest="35" FontSize="12" BackgroundColor="#10B981"/>
                </HorizontalStackLayout>
                <ImageButton Grid.Column="1" Source="filter_white.png" Command="{Binding ToggleFilterCommand}" HeightRequest="30" WidthRequest="30"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" RowDefinitions="Auto, *">
            <Border IsVisible="{Binding IsFilterVisible}" Grid.Row="0" Margin="10" Padding="15" BackgroundColor="White" StrokeShape="RoundRectangle 15">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Фільтрація товарів" FontAttributes="Bold" TextColor="#4F46E5"/>

                    <Entry Placeholder="Пошук за назвою" Text="{Binding Query.Name}"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Entry Placeholder="Мін. ціна" Text="{Binding Query.MinPrice}" Keyboard="Numeric"/>
                        <Entry Grid.Column="1" Placeholder="Макс. ціна" Text="{Binding Query.MaxPrice}" Keyboard="Numeric"/>
                    </Grid>

                    <Picker Title="Категорія товару" ItemsSource="{Binding InventoryTypes}" SelectedItem="{Binding Query.InventoryType}">
                        <Picker.ItemDisplayBinding>
                            <Binding Converter="{StaticResource InventoryTypeToStringConverter}"/>
                        </Picker.ItemDisplayBinding>
                    </Picker>

                    <Button Text="Застосувати" Command="{Binding LoadDataCommand}" BackgroundColor="#4F46E5" TextColor="White" CornerRadius="10"/>
                    <Button Text="Скинути" Command="{Binding ResetFiltersCommand}" BackgroundColor="Transparent" TextColor="Gray"/>
                </VerticalStackLayout>
            </Border>

            <CollectionView Grid.Row="1" ItemsSource="{Binding Items}" Margin="10,5">
                <CollectionView.Header>
                    <Button Text="📊 Згенерувати PDF Звіт" 
                            Command="{Binding GenerateReportCommand}" 
                            BackgroundColor="#EF4444" Margin="0,5,0,10" HeightRequest="45"/>
                </CollectionView.Header>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="m:InventoryResponse">
                        <components:InventoryCard
                            EditCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:InventoryAggregationViewModel}}, Path=OpenDetailsCommand}"
                            DeleteCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:InventoryAggregationViewModel}}, Path=DeleteItemCommand}"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.Footer>
                    <BoxView HeightRequest="80" Color="Transparent"/>
                </CollectionView.Footer>
            </CollectionView>
        </Grid>

        <components:PaginationControl Grid.Row="1" VerticalOptions="End"
                                      PageNumber="{Binding Query.Page}" 
                                      CanNext="{Binding CanGoNext}"
                                      NextCommand="{Binding NextPageCommand}" 
                                      PrevCommand="{Binding PreviousPageCommand}"/>

        <components:LoadingOverlay Grid.RowSpan="2"/>
    </Grid>
</ContentPage>