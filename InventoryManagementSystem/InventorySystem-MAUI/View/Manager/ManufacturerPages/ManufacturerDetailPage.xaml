<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.ManufacturerDetailPage"
             xmlns:vm="clr-namespace:InventorySystem_MAUI.ViewModel"
             x:DataType="vm:ManufacturerDetailsViewModel"
             BackgroundColor="#F8F9FA"
             Shell.PresentationMode="Modal">


    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#4F46E5" Offset="0.0"/>
            <GradientStop Color="#9333EA" Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <VerticalStackLayout VerticalOptions="Center" Padding="20" Spacing="20">

            
            <Label Text="{Binding Title}" FontSize="24" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" Margin="0,10"/>

            <Border StrokeShape="RoundRectangle 16" BackgroundColor="White" Padding="25">
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.1" Offset="0,4" Radius="10"/>
                </Border.Shadow>

                <VerticalStackLayout Spacing="15">
                    <VerticalStackLayout Spacing="5">
                    <Label Text="Назва виробника" FontAttributes="Bold" TextColor="#374151"/>
                    <Entry Text="{Binding Name}" Placeholder="Наприклад: Samsung"/>
                </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                    <Label Text="Країна походження" FontAttributes="Bold" TextColor="#374151"/>
                    <Entry Text="{Binding Country}" Placeholder="Наприклад: Південна Корея"/>
                </VerticalStackLayout>

                    <VerticalStackLayout Spacing="10">
                        <Button Text="Зберегти" 
                             Command="{Binding SaveCommand}" 
                             BackgroundColor="#4F46E5" 
                             BorderColor="Blue"
                             TextColor="White" 
                             HeightRequest="50" 
                             CornerRadius="12"/>

                         <Button Text="Скасувати" 
                             Command="{Binding CancelCommand}" 
                             BorderColor="Red"
                             BackgroundColor="#EF4444" 
                             TextColor="White" 
                             HeightRequest="45"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>

               
            </Border>

    </VerticalStackLayout>
</ContentPage>