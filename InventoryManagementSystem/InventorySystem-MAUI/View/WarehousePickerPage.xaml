<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.WarehousePickerPage"
             xmlns:vm="clr-namespace:InventorySystem_MAUI.ViewModel"
             xmlns:components="clr-namespace:InventorySystem_MAUI.View.Components"
             x:DataType="vm:WarehousePickerViewModel"
             Shell.PresentationMode="Modal"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8F9FA">

    <Grid RowDefinitions="Auto, *, Auto">

        <Grid Grid.Row="0" HeightRequest="130">

            <VerticalStackLayout Padding="20,20,20,10" Spacing="10">
                <Label Text="Виберіть склади" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       HorizontalOptions="Center"/>

                <Border StrokeShape="RoundRectangle 12" 
                        BackgroundColor="White" 
                        HeightRequest="50">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.1" Offset="0,4" Radius="10"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto, *">
                        <Label Text="🔍" VerticalOptions="Center" Margin="15,0,5,0" FontSize="16"/>
                        <Entry Text="{Binding SearchText}" 
                               Placeholder="Пошук за назвою..." 
                               VerticalOptions="Center"
                               TextColor="#1F2937"
                               BackgroundColor="Transparent"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </Grid>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Warehouses}" Margin="15,10">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:WarehouseSelectableItem">
                    <Border StrokeShape="RoundRectangle 16" 
                            Margin="0,5" 
                            Padding="15" 
                            BackgroundColor="White">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WarehousePickerViewModel}}, Path=ToggleSelectionCommand}"
                                CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding Warehouse.Name}" 
                                       FontAttributes="Bold" 
                                       FontSize="16" 
                                       TextColor="#111827"/>
                                <Label Text="{Binding Warehouse.Address.City}" 
                                       TextColor="#6B7280" 
                                       FontSize="13"/>
                            </VerticalStackLayout>

                            <CheckBox Grid.Column="1" 
                                      IsChecked="{Binding IsSelected}" 
                                      InputTransparent="True"
                                      Color="#4F46E5" 
                                      VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.Footer>
                <BoxView HeightRequest="20" Color="Transparent"/>
            </CollectionView.Footer>
        </CollectionView>

        <Border Grid.Row="2" 
                Padding="20,15" 
                BackgroundColor="White" 
                StrokeThickness="1" 
                Stroke="#E5E7EB">
            <VerticalStackLayout Spacing="15">

                <components:PaginationControl HorizontalOptions="FillAndExpand"
                                              PageNumber="{Binding CurrentPage}" 
                                              CanNext="{Binding CanGoNext}"
                                              NextCommand="{Binding NextPageCommand}" 
                                              PrevCommand="{Binding PreviousPageCommand}"/>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <Button Grid.Column="0" 
                            Text="Скасувати" 
                            Command="{Binding CancelCommand}"
                            BackgroundColor="#F3F4F6"
                            TextColor="#374151"
                            CornerRadius="12"
                            HeightRequest="48"
                            FontAttributes="Bold"/>

                    <Button Grid.Column="1" 
                            Text="Підтвердити" 
                            Command="{Binding SaveAndCloseCommand}" 
                            BackgroundColor="#4F46E5" 
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="48"
                            FontAttributes="Bold"/>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <components:LoadingOverlay Grid.RowSpan="3"/>
    </Grid>
</ContentPage>