<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.ProfilePage"
             xmlns:vm="clr-namespace:InventorySystem_MAUI.ViewModel"
             xmlns:components="clr-namespace:InventorySystem_MAUI.View.Components"
             x:DataType="vm:ProfileViewModel"
             BackgroundColor="#F8F9FA"
             Shell.PresentationMode="Modal"
             >

    <Grid RowDefinitions="Auto, *">

        <ScrollView Grid.Row="0" Grid.RowSpan="2" Margin="0,10,0,0">
            <VerticalStackLayout Padding="20" Spacing="20">

                <Border StrokeShape="RoundRectangle 16" BackgroundColor="White" Padding="25">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.1" Offset="0,4" Radius="10"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="15">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <Border HeightRequest="70" WidthRequest="70" StrokeShape="RoundRectangle 35">
                                <Image Source="{Binding CurrentUser.PhotoURI}" Aspect="AspectFill"/>
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Margin="15,0" VerticalOptions="Center">
                                <Label Text="{Binding CurrentUser.Name}" FontSize="20" FontAttributes="Bold"/>
                                <Label Text="{Binding CurrentUser.UserRole}" TextColor="#4F46E5" FontSize="14"/>
                            </VerticalStackLayout>

                            <ImageButton Grid.Column="2" Source="edit.png" Command="{Binding ToggleEditModeCommand}" HeightRequest="25" VerticalOptions="Start"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#F3F4F6"/>

                        <VerticalStackLayout Spacing="10" IsVisible="{Binding IsEditMode, Converter={StaticResource InverseBoolConverter}}">
                            <Label Text="{Binding CurrentUser.Email}" TextColor="#6B7280"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="12" IsVisible="{Binding IsEditMode}">
                            <Entry Text="{Binding EditName}" Placeholder="Ім'я" BackgroundColor="#F9FAFB"/>
                            <Entry Text="{Binding EditEmail}" Placeholder="Email" Keyboard="Email" BackgroundColor="#F9FAFB"/>
                            <Label Text="Зміна пароля (залиште порожнім, якщо не змінюєте)" FontSize="12" TextColor="#9CA3AF" Margin="0,5,0,0"/>
                            <Entry Text="{Binding NewPassword}" Placeholder="Новий пароль" IsPassword="True" BackgroundColor="#F9FAFB"/>
                            <Entry Text="{Binding ConfirmPassword}" Placeholder="Підтвердіть пароль" IsPassword="True" BackgroundColor="#F9FAFB"/>

                            <Button Text="Зберегти" Command="{Binding SaveChangesCommand}" BackgroundColor="#4F46E5" Margin="0,10,0,0"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 16" BackgroundColor="White" Padding="25">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Ваша компанія" FontSize="18" FontAttributes="Bold" TextColor="#111827"/>
                        <Label Text="{Binding Company.Name}" FontSize="16" TextColor="#4F46E5" FontAttributes="Bold"/>
                        <Label Text="{Binding Company.Description}" FontSize="14" TextColor="#6B7280"/>

                        <HorizontalStackLayout Spacing="10" Margin="0,5">
                            <Label Text="📞" VerticalOptions="Center"/>
                            <Label Text="{Binding Company.Phone}" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="10">
                            <Label Text="📍" VerticalOptions="Center"/>
                            <Label Text="{Binding Company.Address.City}" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <components:LoadingOverlay Grid.RowSpan="2" />
    </Grid>
</ContentPage>