<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.WelcomePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource CardColor}">
    
    <Grid RowDefinitions="*, Auto">
        <VerticalStackLayout Grid.Row="0" 
                             VerticalOptions="Center" 
                             Spacing="10" 
                             Padding="30">

            <Border StrokeShape="RoundRectangle 90"
                    HeightRequest="180"
                    WidthRequest="180"
                    HorizontalOptions="Center"
                    Margin="0,0,0,20"
                    StrokeThickness="0">
                <Border.Shadow>
                    <Shadow Brush="{StaticResource PrimaryColor}" 
                            Offset="0,10" 
                            Radius="30" 
                            Opacity="0.15" />
                </Border.Shadow>
                <Image Source="logo.png" 
                       Aspect="AspectFit" />
            </Border>

            <Label Text="Inventory Management System" 
                   Style="{StaticResource TitleLabel}" />

            <Label Text="Повний контроль ваших товарів в одному додатку" 
                   Style="{StaticResource SubtitleLabel}" />

        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1" 
                             Padding="30,0,30,50" 
                             Spacing="15">

            <Button Text="Почати роботу"
                    Clicked="OnGetStartedClicked"
                    HorizontalOptions="Center" />

            <Label Text="Версія 1.0.0" 
                   Style="{StaticResource BodyLabel}" 
                   HorizontalOptions="Center" 
                   Opacity="0.6" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>