<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.WelcomePage"
             Shell.NavBarIsVisible="False">
    <Grid>
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="Magenta" Offset="0.0" />
                    <GradientStop Color="MidnightBlue" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <VerticalStackLayout VerticalOptions="Center" Spacing="20" Padding="30">
            
            <Image Source="logo.png" 
               HeightRequest="180" 
               HorizontalOptions="Center">
                <Image.Shadow>
                    <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.3" />
                </Image.Shadow>
            </Image>

            <Label Text = "Inventory Management System" 
               Style= "{StaticResource TitleLabel}" />

            <Label Text = "Повний контроль ваших товарів в одному додатку" 
               Style="{StaticResource SubtitleLabel}"
               Margin="0,0,0,40" />

            <Button Text="Почати роботу"
                Clicked="OnGetStartedClicked">
            </Button>
            
        </VerticalStackLayout>
    </Grid>
</ContentPage>