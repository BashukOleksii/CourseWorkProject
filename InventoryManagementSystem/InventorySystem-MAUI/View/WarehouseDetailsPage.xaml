<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.WarehouseDetailsPage"
             xmlns:vm="clr-namespace:InventorySystem_MAUI.ViewModel"
             xmlns:components="clr-namespace:InventorySystem_MAUI.View.Components"
             x:DataType="vm:WarehouseDetailsViewModel"
             BackgroundColor="#F8F9FA"
             Shell.NavBarIsVisible="True"
             Shell.PresentationMode="Modal">

    <Grid RowDefinitions="Auto, *">

        <BoxView Grid.Row="0" 
                 HeightRequest="30" 
                 BackgroundColor="#4F46E5" 
                 VerticalOptions="Start"/>

        <ScrollView Grid.Row="0" Grid.RowSpan="2">
            <VerticalStackLayout Padding="20,40,20,30" Spacing="20">

                <Border StrokeShape="RoundRectangle 16" 
                        BackgroundColor="White" 
                        Padding="25">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.1" Offset="0,4" Radius="10"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="18">
                        <Label Text="{Binding Title}" 
                               FontSize="22" 
                               FontAttributes="Bold" 
                               TextColor="#4F46E5"/>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Назва складу" FontAttributes="Bold" TextColor="#374151" Margin="5,0"/>
                            <Border Stroke="#E5E7EB" StrokeShape="RoundRectangle 12" BackgroundColor="#F9FAFB" Padding="12,0">
                                <Entry Text="{Binding Name}" 
                                       Placeholder="Введіть назву..."
                                       TextColor="#111827"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Загальна площа (м²)" FontAttributes="Bold" TextColor="#374151" Margin="5,0"/>
                            <Border Stroke="#E5E7EB" StrokeShape="RoundRectangle 12" BackgroundColor="#F9FAFB" Padding="12,0">
                                <Entry Text="{Binding Area}" 
                                       Keyboard="Numeric" 
                                       Placeholder="0.00"/>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 16" 
                        BackgroundColor="White" 
                        Padding="25">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.1" Offset="0,4" Radius="10"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="15">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="📍" FontSize="20" VerticalOptions="Center"/>
                            <Label Text="Локація" FontSize="18" FontAttributes="Bold" TextColor="#111827" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <VerticalStackLayout Spacing="8" IsVisible="{Binding HasAddress}">
                            <Label Text="{Binding SelectedAddress.City}" 
                                   FontSize="15" 
                                   TextColor="#4B5563"/>
                            <HorizontalStackLayout Spacing="15">
                                <Label Text="{Binding SelectedAddress.Latitude, StringFormat='Lat: {0:F4}'}" FontSize="12" TextColor="#9CA3AF"/>
                                <Label Text="{Binding SelectedAddress.Longitude, StringFormat='Lon: {0:F4}'}" FontSize="12" TextColor="#9CA3AF"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <Button Text="Вибрати або змінити адресу" 
                                Command="{Binding OpenAddressPickerCommand}"
                                BackgroundColor="#EEF2FF"
                                TextColor="#4F46E5"
                                FontAttributes="Bold"
                                CornerRadius="12"
                                HeightRequest="48"/>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 16" 
                        BackgroundColor="White" 
                        Padding="25">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Додаткові примітки" FontAttributes="Bold" TextColor="#374151" Margin="5,0"/>
                        <Editor Text="{Binding Description}" 
                                Placeholder="Опишіть особливості складу..." 
                                AutoSize="TextChanges" 
                                MinimumHeightRequest="100"
                                TextColor="#111827"
                                Margin="0,5,0,0"/>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="12">
                    <Button Text="Зберегти зміни" 
                            Command="{Binding SaveCommand}"
                            BackgroundColor="#4F46E5"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="14"
                            HeightRequest="56">
                        <Button.Shadow>
                            <Shadow Brush="#4F46E5" Opacity="0.3" Offset="0,4" Radius="8"/>
                        </Button.Shadow>
                    </Button>

                    <Button Text="Скасувати" 
                            Command="{Binding CancelCommand}"
                            BackgroundColor="Transparent"
                            TextColor="#6B7280"
                            CornerRadius="14"
                            HeightRequest="50"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <components:LoadingOverlay Grid.RowSpan="2" />

    </Grid>
</ContentPage>