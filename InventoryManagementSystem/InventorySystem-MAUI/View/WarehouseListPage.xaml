<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.WarehouseListPage"
             xmlns:vm="clr-namespace:InventorySystem_MAUI.ViewModel"
             xmlns:m="clr-namespace:InventorySystem_Shared.Warehouse;assembly=InventorySystem-Shared"
             x:DataType="vm:WarehouseListViewModel">

    <Grid RowDefinitions="Auto, Auto, *, Auto">

        <Grid Grid.Row="0" HeightRequest="80" Padding="20,0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#4F46E5" Offset="0.0"/>
                    <GradientStop Color="#9333EA" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Label Text="Склади" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   TextColor="White" 
                   VerticalOptions="Center"/>

            <ImageButton Source="report_icon.png" 
                         Command="{Binding GoToReportsCommand}"
                         HorizontalOptions="End" 
                         VerticalOptions="Center"
                         HeightRequest="40" 
                         WidthRequest="40" 
                         BackgroundColor="Transparent"/>
        </Grid>

        <Border Grid.Row="1" 
                Margin="15,10" 
                StrokeShape="RoundRectangle 12" 
                Stroke="#E5E7EB" 
                BackgroundColor="White">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.05" Offset="0,2" Radius="5"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto, *">
                <Label Text="🔍" VerticalOptions="Center" Margin="12,0,5,0" FontSize="16"/>
                <Entry Grid.Column="1"
                       Text="{Binding SearchText}"
                       Placeholder="Пошук складу за назвою..."
                       FontSize="15"
                       TextColor="#1F2937"
                       PlaceholderColor="#9CA3AF"
                       HeightRequest="48"
                       VerticalOptions="Center"/>
            </Grid>
        </Border>

        <RefreshView Grid.Row="2" 
                     Command="{Binding LoadWarehousesCommand}" 
                     IsRefreshing="{Binding IsBusy}">

            <Grid>
                <CollectionView ItemsSource="{Binding Warehouses}" 
                                SelectionMode="None" 
                                Margin="15,5">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="m:WarehouseResponse">
                            <Border StrokeShape="RoundRectangle 16" 
                                    BackgroundColor="White"
                                    Padding="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WarehouseViewModel}}, Path=EditWarehouseCommand}" 
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Opacity="0.1" Offset="0,3" Radius="6"/>
                                </Border.Shadow>

                                <Grid ColumnDefinitions="Auto, *" Padding="15" ColumnSpacing="15">
                                    <Border Grid.Column="0" 
                                            HeightRequest="55" 
                                            WidthRequest="55" 
                                            StrokeShape="RoundRectangle 12" 
                                            BackgroundColor="#EEF2FF"
                                            StrokeThickness="0">
                                        <Label Text="🏢" FontSize="26" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Name}" 
                                               FontSize="17" 
                                               FontAttributes="Bold" 
                                               TextColor="#111827"/>
                                        <Label Text="{Binding Address.City}" 
                                               FontSize="14" 
                                               TextColor="#6B7280"/>
                                        <Label Text="{Binding Area, StringFormat='{0} м²'}" 
                                               FontSize="13" 
                                               TextColor="#4F46E5" 
                                               FontAttributes="Bold"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Margin="0,50">
                            <Label Text="Нічого не знайдено" TextColor="#9CA3AF" FontSize="16" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>

                <Button Text="+"
                        FontSize="30"
                        TextColor="White"
                        BackgroundColor="#6366F1"
                        HeightRequest="60"
                        WidthRequest="60"
                        CornerRadius="30"
                        HorizontalOptions="End"
                        VerticalOptions="End"
                        Margin="20"
                        Command="{Binding AddWarehouseCommand}">
                    <Button.Shadow>
                        <Shadow Brush="Black" Opacity="0.3" Offset="0,5" Radius="10"/>
                    </Button.Shadow>
                </Button>
            </Grid>
        </RefreshView>

        <Border Grid.Row="3" 
                BackgroundColor="White" 
                Padding="15,10" 
                StrokeThickness="1" 
                Stroke="#F3F4F6">
            <Grid ColumnDefinitions="*, Auto, *">
                <Button Grid.Column="0" 
                        Text="Назад" 
                        Command="{Binding PreviousPageCommand}" 
                        BackgroundColor="#F3F4F6" 
                        TextColor="#374151" 
                        HeightRequest="42" 
                        CornerRadius="12"/>

                <Label Grid.Column="1" 
                       Text="{Binding CurrentPage, StringFormat='Сторінка {0}'}" 
                       VerticalOptions="Center" 
                       Margin="20,0" 
                       FontAttributes="Bold"
                       TextColor="#111827"/>

                <Button Grid.Column="2" 
                        Text="Далі" 
                        Command="{Binding NextPageCommand}" 
                        IsEnabled="{Binding CanGoNext}"
                        BackgroundColor="#6366F1" 
                        TextColor="White"
                        HeightRequest="42" 
                        CornerRadius="12"/>
            </Grid>
        </Border>

        <Grid BackgroundColor="#80000000" 
              IsVisible="{Binding IsBusy}" 
              Grid.RowSpan="4"
              InputTransparent="False">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="White" HeightRequest="60" WidthRequest="60"/>
                <Label Text="Завантаження..." TextColor="White" FontAttributes="Bold"/>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>