<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.WarehouseListPage"
             xmlns:vm="clr-namespace:InventorySystem_MAUI.ViewModel"
             xmlns:m="clr-namespace:InventorySystem_Shared.Warehouse;assembly=InventorySystem-Shared"
             xmlns:components="clr-namespace:InventorySystem_MAUI.View.Components"
             x:DataType="vm:WarehouseListViewModel">

    <Grid RowDefinitions="Auto, Auto, *, Auto">

        <Grid Grid.Row="0" HeightRequest="80" Padding="20,0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#4F46E5" Offset="0.0"/>
                    <GradientStop Color="#9333EA" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Label Text="Склади" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   TextColor="White" 
                   VerticalOptions="Center"/>

            <ImageButton Source="report_icon.png" 
                         Command="{Binding GoToReportsCommand}"
                         HorizontalOptions="End" 
                         VerticalOptions="Center"
                         HeightRequest="40" 
                         WidthRequest="40" 
                         BackgroundColor="Transparent"/>
        </Grid>

        <Border Grid.Row="1" 
                Margin="15,10" 
                StrokeShape="RoundRectangle 12" 
                Stroke="#E5E7EB" 
                BackgroundColor="White">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.05" Offset="0,2" Radius="5"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto, *">
                <Label Text="🔍" VerticalOptions="Center" Margin="12,0,5,0" FontSize="16"/>
                <Entry Grid.Column="1"
                       Text="{Binding SearchText}"
                       Placeholder="Пошук складу за назвою..."
                       FontSize="15"
                       TextColor="#1F2937"
                       PlaceholderColor="#9CA3AF"
                       HeightRequest="48"
                       VerticalOptions="Center"/>
            </Grid>
        </Border>

        <RefreshView Grid.Row="2" 
                     Command="{Binding LoadWarehousesCommand}" 
                     IsRefreshing="{Binding IsBusy}">

            <Grid>
                
                <CollectionView 
                    ItemsSource="{Binding Warehouses}"
                    ItemTemplate="{StaticResource Key=WarehouseCardTemplate}"
                    Margin="15,5">
                </CollectionView>

                <components:AddButton AddCommand="{Binding AddWarehouseCommand}"/>

            </Grid>
            
        </RefreshView>

        <components:PaginationControl 
            Grid.Row="3"
            PageNumber="{Binding CurrentPage}"
            CanNext="{Binding CanGoNext}"
            NextCommand="{Binding NextPageCommand}"
            PrevCommand="{Binding PreviousPageCommand}"/>

        <components:LoadingOverlay Grid.RowSpan="4" />

    </Grid>
</ContentPage>