<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.WarehouseListPage"
             xmlns:vm="clr-namespace:InventorySystem_MAUI.ViewModel"
             xmlns:m="clr-namespace:InventorySystem_Shared.Warehouse;assembly=InventorySystem-Shared"
             xmlns:components="clr-namespace:InventorySystem_MAUI.View.Components"
             x:DataType="vm:WarehouseListViewModel"
             BackgroundColor="#F8F9FA">
    
    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" HeightRequest="60">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#4F46E5" Offset="0.0"/>
                    <GradientStop Color="Transparent" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Border Margin="15,0"
                    VerticalOptions="Start"
                    StrokeShape="RoundRectangle 12" 
                    Stroke="#E5E7EB" 
                    BackgroundColor="White"
                    HeightRequest="50">
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.1" Offset="0,4" Radius="10"/>
                </Border.Shadow>

                <Grid ColumnDefinitions="Auto, *, Auto">
                    <Label Text="🔍" VerticalOptions="Center" Margin="15,0,5,0" FontSize="16"/>
                    <Entry Grid.Column="1"
                           Text="{Binding SearchText}"
                           Placeholder="Пошук складу..."
                           FontSize="15"
                           TextColor="#1F2937"
                           VerticalOptions="Center"
                           BackgroundColor="Transparent"/>

                    <ImageButton Grid.Column="2"
                                 Source="report_icon.png"
                                 Command="{Binding GoToReportsCommand}"
                                 Margin="0,0,10,0"
                                 HeightRequest="25"
                                 WidthRequest="25"
                                 VerticalOptions="Center"/>
                </Grid>
            </Border>
        </Grid>

        <RefreshView Grid.Row="1" 
                     Command="{Binding LoadWarehousesCommand}" 
                     IsRefreshing="{Binding IsBusy}"
                     Margin="0,10,0,0">
            <Grid>
                <CollectionView ItemsSource="{Binding Warehouses}"
                                Margin="15,0">
                    <CollectionView.Header>
                        <Label Text="Ваші локації" 
                               FontSize="18" 
                               FontAttributes="Bold" 
                               Margin="5,0,0,10"
                               TextColor="#1F2937"/>
                    </CollectionView.Header>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="m:WarehouseResponse">
                            <components:WarehouseCardView 
                                EditCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:WarehouseListViewModel}}, Path=EditWarehouseCommand}"
                                DeleteCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:WarehouseListViewModel}}, Path=DeleteCommand}"/>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <CollectionView.Footer>
                        <BoxView HeightRequest="80" Color="Transparent"/>
                    </CollectionView.Footer>
                </CollectionView>

                <components:AddButton AddCommand="{Binding AddWarehouseCommand}"
                                     VerticalOptions="End"
                                     HorizontalOptions="End"
                                     Margin="20,0,20,80"/>
            </Grid>
        </RefreshView>

        <components:PaginationControl 
            Grid.Row="1"
            VerticalOptions="End"
            PageNumber="{Binding CurrentPage}"
            CanNext="{Binding CanGoNext}"
            NextCommand="{Binding NextPageCommand}"
            PrevCommand="{Binding PreviousPageCommand}"/>

        <components:LoadingOverlay Grid.RowSpan="2" />
    </Grid>
</ContentPage>