<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.InventoryDetailsPage"
             xmlns:vm="clr-namespace:InventorySystem_MAUI.ViewModel"
             xmlns:components="clr-namespace:InventorySystem_MAUI.View.Components"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:DataType="vm:InventoryDetailsViewModel"
             Title="{Binding Title}"
             BackgroundColor="#F8F9FA">

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="20">

                <Border StrokeShape="RoundRectangle 20" HeightRequest="220" BackgroundColor="White" Padding="0">
                    <Grid>
                        <Image Source="{Binding PreviewImage}" Aspect="AspectFill" />
                        <BoxView BackgroundColor="#40000000" />
                        <Button Text="📷 Обрати фотографію" 
                                Command="{Binding PickPhotoCommand}"
                                VerticalOptions="Center" HorizontalOptions="Center"
                                BackgroundColor="#4F46E5" CornerRadius="15"/>
                    </Grid>
                </Border>

                <Border StrokeShape="RoundRectangle 16" BackgroundColor="White" Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Загальна інформація" FontAttributes="Bold" FontSize="18" TextColor="#4F46E5"/>

                        <Entry Placeholder="Назва техніки" Text="{Binding Name}" FontSize="16"/>
                        <Editor Placeholder="Детальний опис..." Text="{Binding Description}" AutoSize="TextChanges" MinimumHeightRequest="80"/>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="Ціна (₴)" FontSize="12" TextColor="Gray"/>
                                <Entry Text="{Binding Price}" Keyboard="Numeric"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="Кількість" FontSize="12" TextColor="Gray"/>
                                <Entry Text="{Binding Quantity}" Keyboard="Numeric"/>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 16" BackgroundColor="White" Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Класифікація" FontAttributes="Bold" FontSize="18" TextColor="#4F46E5"/>

                        <Label Text="Тип товару" FontSize="12" Margin="5,0"/>
                        <Picker ItemsSource="{Binding InventoryTypes}" SelectedItem="{Binding SelectedType}">
                            <Picker.ItemDisplayBinding>
                                <Binding Converter="{StaticResource InventoryTypeToStringConverter}"/>
                            </Picker.ItemDisplayBinding>
                        </Picker>

                        <Label Text="Виробник" FontSize="12" Margin="5,0"/>
                        <Picker ItemsSource="{Binding Manufacturers}" 
                                SelectedItem="{Binding SelectedManufacturer}"
                                ItemDisplayBinding="{Binding Name}"
                                Title="Оберіть зі свого списку"/>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 16" BackgroundColor="White" Padding="20">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Характеристики" FontAttributes="Bold" FontSize="18" VerticalOptions="Center"/>
                            <Button Grid.Column="1" Text="+ Додати" Command="{Binding AddFieldCommand}" 
                                    BackgroundColor="#EEF2FF" TextColor="#4F46E5" HeightRequest="35"/>
                        </Grid>

                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding DynamicFields}" Spacing="10" Margin="0,10,0,0">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:CustomFieldItem">
                                    <Grid ColumnDefinitions="*, *, Auto" ColumnSpacing="8">
                                        <Border Stroke="#E5E7EB" StrokeShape="RoundRectangle 8" Padding="5,0">
                                            <Entry Text="{Binding Key}" Placeholder="Властивість" FontSize="13"/>
                                        </Border>
                                        <Border Grid.Column="1" Stroke="#E5E7EB" StrokeShape="RoundRectangle 8" Padding="5,0">
                                            <Entry Text="{Binding Value}" Placeholder="Значення" FontSize="13"/>
                                        </Border>
                                        <ImageButton Grid.Column="2" Source="delete_red.png" 
                                                     Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InventoryDetailsViewModel}}, Path=RemoveFieldCommand}"
                                                     CommandParameter="{Binding .}"
                                                     HeightRequest="30" WidthRequest="30"/>
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1" Padding="20,15" BackgroundColor="White" StrokeThickness="1" Stroke="#E5E7EB">
            <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                <Button Text="Скасувати" Command="{Binding CancelCommand}" BackgroundColor="#F3F4F6" TextColor="Black" CornerRadius="12"/>
                <Button Grid.Column="1" Text="Зберегти" Command="{Binding SaveCommand}" BackgroundColor="#4F46E5" TextColor="White" FontAttributes="Bold" CornerRadius="12"/>
            </Grid>
        </Border>

        <components:LoadingOverlay Grid.RowSpan="2"/>
    </Grid>
</ContentPage>