<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.ForgotPasswordPage"
             xmlns:vm="clr-namespace:InventorySystem_MAUI.ViewModel"
             x:DataType="vm:ForgotPasswordViewModel"
             Shell.NavBarIsVisible="False"
             Shell.PresentationMode="Modal">
    

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#4F46E5" Offset="0.0"/>
                <GradientStop Color="#9333EA" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Padding="25" Spacing="0" VerticalOptions="Center">

                <Label Text="Відновлення"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"/>

                <Label Text="Ми відправимо код підтвердження на пошту"
                       FontSize="14"
                       TextColor="#E0E0E0"
                       HorizontalOptions="Center"
                       Margin="0,5,0,30"
                       IsVisible="{Binding IsCodeSent, Converter={StaticResource InvertedBoolConverter}}"/>

                <Border StrokeShape="RoundRectangle 25"
                        BackgroundColor="White"
                        Padding="25"
                        Margin="0,0,0,20">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Opacity="0.2" Offset="0,5" Radius="15"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="18">

                        <VerticalStackLayout Spacing="5" IsVisible="{Binding IsCodeSent, Converter={StaticResource InverseBoolConverter}}">
                            <Label Text="Ваш Email" FontAttributes="Bold" TextColor="#333"/>
                            <Border Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="10">
                                <Entry Text="{Binding Email}" Placeholder="example@mail.com" Keyboard="Email"/>
                            </Border>
                            <Button Text="Отримати код"
                                    Command="{Binding SendCodeCommand}"
                                    HeightRequest="55" CornerRadius="18"
                                    BackgroundColor="#6366F1" Margin="0,15,0,0"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="18" IsVisible="{Binding IsCodeSent}">
                            <Label Text="Код підтвердження" FontAttributes="Bold" TextColor="#333"/>
                            <Border Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="10">
                                <Entry Text="{Binding ResetCode}" Placeholder="1234567" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
                            </Border>

                            <Label Text="Новий пароль" FontAttributes="Bold" TextColor="#333"/>
                            <Border Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="10">
                                <Entry Text="{Binding NewPassword}" Placeholder="********" IsPassword="True"/>
                            </Border>

                            <Button Text="Змінити пароль"
                                    Command="{Binding ResetPasswordCommand}"
                                    HeightRequest="55" CornerRadius="18"
                                    BackgroundColor="#10B981" Margin="0,10,0,0"/>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <Label Text="Повернутися до входу"
                       TextColor="White"
                       HorizontalOptions="Center"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </ScrollView>

        <Grid BackgroundColor="#80000000" IsVisible="{Binding IsBusy}">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="White" HeightRequest="60" WidthRequest="60"/>
                <Label Text="Обробка запиту..." TextColor="White" FontAttributes="Bold"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>