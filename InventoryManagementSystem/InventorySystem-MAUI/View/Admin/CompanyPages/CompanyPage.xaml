<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.CompanyPage"
             xmlns:vm="clr-namespace:InventorySystem_MAUI.ViewModel"
             xmlns:components="clr-namespace:InventorySystem_MAUI.View.Components"
             x:DataType="vm:CompanyViewModel"
             BackgroundColor="#F8F9FA">

    <Grid RowDefinitions="Auto, *">

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#4F46E5" Offset="0.0"/>
                <GradientStop Color="#9333EA" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <ScrollView Grid.Row="0" Grid.RowSpan="2">
            <VerticalStackLayout Padding="20,40,20,30" Spacing="20">

                <Label Text="Моя Компанія" TextColor="White" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,0,0,10"/>

                <Border StrokeShape="RoundRectangle 16" BackgroundColor="White" Padding="20">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.1" Offset="0,4" Radius="10"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="15">
                        <Label Text="Основна інформація" FontSize="18" FontAttributes="Bold" TextColor="#4F46E5"/>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Назва компанії" FontAttributes="Bold" FontSize="12" TextColor="#6B7280"/>
                            <Entry Text="{Binding Name}" Placeholder="Введіть назву"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Опис" FontAttributes="Bold" FontSize="12" TextColor="#6B7280"/>
                            <Editor Text="{Binding Description}" AutoSize="TextChanges" Placeholder="Про компанію"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="Телефон" FontAttributes="Bold" FontSize="12" TextColor="#6B7280"/>
                            <Entry Text="{Binding Phone}" Keyboard="Telephone" Placeholder="+380..."/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 16" BackgroundColor="White" Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Адреса" FontSize="18" FontAttributes="Bold" TextColor="#4F46E5" VerticalOptions="Center"/>
                            <Button Grid.Column="1" Text="Змінити" Command="{Binding EditAddressCommand}" 
                                    BackgroundColor="#EEF2FF" TextColor="#4F46E5" HeightRequest="35" FontSize="12"/>
                        </Grid>

                        <Border Stroke="#F3F4F6" BackgroundColor="#F9FAFB" Padding="15" StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="{Binding Address.City, StringFormat='м. {0}'}" FontSize="16" FontAttributes="Bold"/>
                                <Label Text="{Binding Address.Street, StringFormat='вул. {0}'}" FontSize="14"/>
                                <Label Text="{Binding Address.State, StringFormat='Область: {0}'}" FontSize="12" TextColor="#6B7280"/>
                                <Label Text="{Binding Address.Country}" FontSize="12" TextColor="#6B7280"/>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Button Text="Зберегти всі зміни" 
                        BorderColor="Blue"
                        Command="{Binding SaveChangesCommand}"
                        BackgroundColor="#4F46E5" 
                        TextColor="White" 
                        FontAttributes="Bold" 
                        HeightRequest="56" 
                        CornerRadius="14"
                        Margin="0,10,0,0"/>

            </VerticalStackLayout>
        </ScrollView>

        <components:LoadingOverlay Grid.RowSpan="2"/>
    </Grid>
</ContentPage>