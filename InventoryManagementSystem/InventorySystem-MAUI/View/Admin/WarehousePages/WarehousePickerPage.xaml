<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.WarehousePickerPage"
             xmlns:vm="clr-namespace:InventorySystem_MAUI.ViewModel"
             xmlns:components="clr-namespace:InventorySystem_MAUI.View.Components"
             x:DataType="vm:WarehousePickerViewModel"
             Shell.PresentationMode="Modal"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8F9FA">

    <Grid RowDefinitions="Auto, *, Auto">

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#4F46E5" Offset="0.0"/>
                <GradientStop Color="#9333EA" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Grid.Row="0" HeightRequest="130">

            <VerticalStackLayout Padding="20,20,20,10" Spacing="10">
                <Label Text="Вибір локацій" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       HorizontalOptions="Center"/>

                <Border StrokeShape="RoundRectangle 12" 
                        BackgroundColor="White" 
                        HeightRequest="50"
                        StrokeThickness="0"
                        Padding="10,0,10,0">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.15" Offset="0,4" Radius="10"/>
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto,*">
                        <ImageButton HeightRequest="40" WidthRequest="35" Source="back_arrow.png" Command="{Binding CancelCommand}" Margin="0,0,10,0"/>
                        <Entry
                            Grid.Column="1"
                           Text="{Binding SearchText}" 
                           Placeholder="Шукати за назвою" 
                           VerticalOptions="Center"
                           HorizontalOptions="Fill"
                           TextColor="#1F2937"
                           BackgroundColor="Transparent"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </Grid>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Warehouses}" Margin="15,5">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:WarehouseSelectableItem">
                    <Border StrokeShape="RoundRectangle 16" 
                            Margin="0,5" 
                            Padding="18,15" 
                            BackgroundColor="White">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WarehousePickerViewModel}}, Path=ToggleSelectionCommand}"
                                CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding Warehouse.Name}" 
                                       FontAttributes="Bold" 
                                       FontSize="16" 
                                       TextColor="#111827"/>
                                <Label Text="{Binding Warehouse.Address.City}" 
                                       TextColor="#6B7280" 
                                       FontSize="13"/>
                            </VerticalStackLayout>

                            <CheckBox Grid.Column="1" 
                                      IsChecked="{Binding IsSelected}" 
                                      InputTransparent="True"
                                      Color="#4F46E5" 
                                      Scale="1.1"
                                      VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.Footer>
                <BoxView HeightRequest="20" Color="Transparent"/>
            </CollectionView.Footer>
        </CollectionView>

        <Border Grid.Row="2" 
                Padding="0" 
                BackgroundColor="#9333EA"
                StrokeShape="RoundRectangle 20,20,0,0">

            <VerticalStackLayout Spacing="5">

               



                <Button Grid.Column="1" 
                            Text="Підтвердити" 
                            Command="{Binding SaveAndCloseCommand}" 
                            BackgroundColor="#4F46E5" 
                            TextColor="White"
                            CornerRadius="20"
                            HeightRequest="52"
                            FontAttributes="Bold">
                </Button>
                
                <components:PaginationControl 
                               PageNumber="{Binding CurrentPage}" 
                               CanNext="{Binding CanGoNext}"
                               NextCommand="{Binding NextPageCommand}" 
                               PrevCommand="{Binding PreviousPageCommand}"/>


            </VerticalStackLayout>
        </Border>

        <components:LoadingOverlay Grid.RowSpan="3"/>
    </Grid>
</ContentPage>