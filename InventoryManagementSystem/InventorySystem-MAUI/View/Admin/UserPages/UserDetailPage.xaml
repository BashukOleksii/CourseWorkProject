<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InventorySystem_MAUI.View.UserDetailPage"
             xmlns:vm="clr-namespace:InventorySystem_MAUI.ViewModel"
             xmlns:components="clr-namespace:InventorySystem_MAUI.View.Components"
             x:DataType="vm:UserDetailViewModel"
             BackgroundColor="#F8F9FA"
             Shell.NavBarIsVisible="False"
             Shell.PresentationMode="Modal">

    <Grid RowDefinitions="Auto, *">

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#4F46E5" Offset="0.0"/>
                <GradientStop Color="#9333EA" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView Grid.Row="0" Grid.RowSpan="2">
            <VerticalStackLayout Padding="20,15,20,30" Spacing="20">

                <Grid ColumnDefinitions="Auto, *">
                    <ImageButton  WidthRequest="35" HeightRequest="35" BackgroundColor="Transparent" Source="back_arrow.png" Command="{Binding GoBackCommand}"/>
                    <Label Grid.Column="1" Text="Профіль співробітника" 
                           TextColor="White" FontSize="20" FontAttributes="Bold"
                           VerticalOptions="Center" HorizontalOptions="Center" Margin="0,0,80,0"/>
                </Grid>

                <Border StrokeShape="RoundRectangle 16" BackgroundColor="White" Padding="25">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.1" Offset="0,4" Radius="10"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
                        <Border HeightRequest="120" WidthRequest="120" StrokeShape="RoundRectangle 60" StrokeThickness="0">
                            <Image Source="{Binding User.PhotoURI , Converter={StaticResource UriConverter}}" Aspect="AspectFill"/>
                        </Border>

                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="{Binding User.Name}" FontSize="24" FontAttributes="Bold" TextColor="#111827" HorizontalOptions="Center"/>
                            <Label Text="{Binding User.UserRole}" FontSize="16" TextColor="#4F46E5" FontAttributes="Bold" HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="#F3F4F6" HorizontalOptions="Fill"/>

                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="📧" FontSize="18"/>
                                <Label Text="{Binding User.Email}" FontSize="16" TextColor="#4B5563" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="🆔" FontSize="18"/>
                                <Entry   IsReadOnly="True" FontSize="12"
                                               BackgroundColor="Transparent" HeightRequest="22" Margin="0" Text="{Binding User.Id}"  TextColor="#9CA3AF" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 16" 
                        BackgroundColor="White" 
                        Padding="25"
                        IsVisible="{Binding IsManager}">
                    <VerticalStackLayout Spacing="15">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="🏢" FontSize="22"/>
                            <Label Text="Доступ до локацій" FontSize="18" FontAttributes="Bold" TextColor="#111827" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <Label Text="{Binding WarehouseCountText}" FontSize="15" TextColor="#6B7280"/>

                        <Button Text="Змінити список складів" 
                                Command="{Binding OpenWarehousePickerCommand}"
                                BackgroundColor="#EEF2FF" 
                                TextColor="#4F46E5" 
                                FontAttributes="Bold"
                                HeightRequest="50"
                                CornerRadius="12"/>

                        <Label Text="* Адміністратори мають доступ до всіх складів за замовчуванням." 
                               FontSize="11" TextColor="#9CA3AF" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <components:LoadingOverlay Grid.RowSpan="2"/>
    </Grid>
</ContentPage>