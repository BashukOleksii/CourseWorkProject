<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:InventorySystem_MAUI"
             x:Class="InventorySystem_MAUI.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary>

                    <Color x:Key="PrimaryColor">#4F46E5</Color>
                    <Color x:Key="PrimaryDark">#4338CA</Color>
                    <Color x:Key="SecondaryColor">#10B981</Color>

                    <Color x:Key="BackgroundColor">#F8FAFC</Color>
                    <Color x:Key="CardColor">#FFFFFF</Color>

                    <Color x:Key="TextPrimary">#1E293B</Color>
                    <Color x:Key="TextSecondary">#64748B</Color>

                    <Color x:Key="BorderColor">#E2E8F0</Color>

                    <Style TargetType="ContentPage">
                        <Setter Property="BackgroundColor" Value="{StaticResource BackgroundColor}" />
                    </Style>
                    

                    
                    
                    <Style x:Key="TitleLabel" TargetType="Label">
                        <Setter Property="FontSize" Value="26"/>
                        <Setter Property="FontAttributes" Value="Bold"/>
                        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
                    </Style>

                    <Style x:Key="SubtitleLabel" TargetType="Label">
                        <Setter Property="FontSize" Value="18"/>
                        <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
                    </Style>

                    <Style x:Key="BodyLabel" TargetType="Label">
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
                    </Style>
                    
                    

                    <Style TargetType="Button">
                        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}" />
                        <Setter Property="TextColor" Value="White"/>
                        <Setter Property="CornerRadius" Value="10"/>
                        <Setter Property="Padding" Value="14,10"/>
                        <Setter Property="FontAttributes" Value="Bold"/>
                        <Setter Property="FontSize" Value="16"/>
                    </Style>

                    <Style x:Key="SecondaryButton" TargetType="Button">
                        <Setter Property="BackgroundColor" Value="{StaticResource SecondaryColor}" />
                        <Setter Property="TextColor" Value="White"/>
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                    
                    
                    

                    <Style TargetType="Entry">
                        <Setter Property="BackgroundColor" Value="White"/>
                        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
                        <Setter Property="PlaceholderColor" Value="{StaticResource TextSecondary}"/>
                        <Setter Property="HeightRequest" Value="45"/>
                    </Style>

                    <Style TargetType="Frame">
                        <Setter Property="BackgroundColor" Value="{StaticResource CardColor}" />
                        <Setter Property="CornerRadius" Value="12"/>
                        <Setter Property="Padding" Value="16"/>
                        <Setter Property="HasShadow" Value="True"/>
                        <Setter Property="BorderColor" Value="{StaticResource BorderColor}"/>
                    </Style>

                    <Style TargetType="CollectionView">
                        <Setter Property="BackgroundColor" Value="Transparent"/>
                    </Style>

                    <Style TargetType="SearchBar">
                        <Setter Property="BackgroundColor" Value="White"/>
                        <Setter Property="HeightRequest" Value="45"/>
                    </Style>

                    <Style TargetType="Picker">
                        <Setter Property="BackgroundColor" Value="White"/>
                        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
                    </Style>

                    <Style x:Key="Divider" TargetType="BoxView">
                        <Setter Property="HeightRequest" Value="1"/>
                        <Setter Property="BackgroundColor" Value="{StaticResource BorderColor}"/>
                    </Style>
                    
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
