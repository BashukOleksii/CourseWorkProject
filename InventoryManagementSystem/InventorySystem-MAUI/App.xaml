<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:InventorySystem_MAUI"
             xmlns:converters="clr-namespace:InventorySystem_MAUI.Converters"
             x:Class="InventorySystem_MAUI.App"
             >
    <Application.Resources>
        <ResourceDictionary>
            
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Ressources/Styles/Styles.xaml" />
                <ResourceDictionary Source="/Resources/Styles/BaseStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:UriConverter x:Key="UriConverter" />
            <converters:ActionToColorConverter x:Key="ActionToColorConverter" />
            <converters:InventoryTypeToStringConverter x:Key="InventoryTypeToStringConverter" />

        </ResourceDictionary>
    </Application.Resources>
</Application>
