<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:m="clr-namespace:InventorySystem_Shared.Warehouse;assembly=InventorySystem-Shared"
                    x:Class="InventorySystem_MAUI.Resources.Styles.Template">

    <DataTemplate x:Key="WarehouseCardTemplate" x:DataType="m:WarehouseResponse">
        <Border StrokeShape="RoundRectangle 16" BackgroundColor="White" Padding="15" Margin="0,5">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.1" Offset="0,3" Radius="6"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto, *">
                <Border HeightRequest="55" WidthRequest="55" StrokeShape="RoundRectangle 12" BackgroundColor="#EEF2FF" StrokeThickness="0">
                    <Label Text="🏢" FontSize="26" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="15,0,0,0" VerticalOptions="Center">
                    <Label Text="{Binding Name}" FontSize="17" FontAttributes="Bold" TextColor="#111827"/>
                    <Label Text="{Binding Address.City}" FontSize="14" TextColor="#6B7280"/>
                    <Label Text="{Binding Area, StringFormat='{0} м²'}" FontSize="13" TextColor="#4F46E5" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Grid>
        </Border>
    </DataTemplate>
</ResourceDictionary>